rules_version = '2';

// Aplica estas reglas a tu bucket de Firebase Storage
service firebase.storage {
  match /b/{bucket}/o {

    // --- REGLAS PARA ARCHIVOS DE USUARIO ---
    // La ruta es /users/{userId}/...
    match /users/{userId}/{allPaths=**} {

      // Lectura: Cualquiera puede ver las imágenes (necesario para avatares y fotos de historias públicas).
      allow read: if true;

      // Escritura: Solo el dueño de la carpeta puede subir archivos.
      // Además, validamos que sean imágenes y no superen los 5MB.
      allow write: if request.auth != null 
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
