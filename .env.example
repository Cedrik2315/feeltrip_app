# FeelTrip Environment Example - COPY to .env and fill keys
# NEVER commit .env

# Firebase
FIREBASE_API_KEY=AIzaSy...
FIREBASE_AUTH_DOMAIN=...
FIREBASE_PROJECT_ID=...
FIREBASE_STORAGE_BUCKET=...
FIREBASE_MESSAGING_SENDER_ID=...
FIREBASE_APP_ID=...

# RevenueCat
REVENUECAT_ANDROID_KEY=sk_...
REVENUECAT_IOS_KEY=appl_...

# MercadoPago
MERCADOPAGO_ACCESS_TOKEN=APP_USR-...
MERCADOPAGO_PUBLIC_KEY=...

# Google AI
GOOGLE_AI_API_KEY=AIzaSy...

# OpenWeather
OPENWEATHER_API_KEY=...

# Sentry (optional)
SENTRY_DSN=https://...

FLUTTER_ENV=production
